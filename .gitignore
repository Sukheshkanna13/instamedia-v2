# ============================================================================
# InstaMedia AI - Git Ignore Configuration
# ============================================================================
# This file ensures sensitive data (API keys, secrets) are never committed
# ============================================================================

# ─── CRITICAL: Environment Variables (NEVER COMMIT!) ───────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
!.env.example
backend/.env
backend/.env.local
frontend/.env
frontend/.env.local

# ─── Python ─────────────────────────────────────────────────────────────────
backend/venv/
backend/__pycache__/
backend/*.pyc
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ─── Node / JavaScript ──────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/build/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/

# ─── IDE / Editors ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.sublime-project

# ─── Operating System ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Logs ───────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Testing ────────────────────────────────────────────────────────────────
coverage/
*.cover
.hypothesis/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ─── Temporary Files ────────────────────────────────────────────────────────
*.tmp
*.temp
.cache/
.parcel-cache/
.next/
.nuxt/
.vuepress/dist

# ─── Database ───────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ─── Secrets & Credentials (EXTRA PROTECTION) ───────────────────────────────
*secret*
*credential*
*password*
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
# But keep example files
!.env.example
!backend/.env.example
!frontend/.env.example

# ─── AWS ────────────────────────────────────────────────────────────────────
.aws/
*.pem

# ─── Backup Files ───────────────────────────────────────────────────────────
*.bak
*.backup
*~

# ─── Build Artifacts ────────────────────────────────────────────────────────
dist/
build/
out/
target/

# ─── Package Manager Lock Files (Optional - uncomment if needed) ────────────
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ─── Local Configuration ────────────────────────────────────────────────────
.local/
local.settings.json

# ============================================================================
# End of .gitignore
# ============================================================================
