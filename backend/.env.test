# Test environment variables
# Copy from .env and modify for testing

# Use test Supabase project or separate buckets
TEST_SUPABASE_URL=your_test_supabase_url
TEST_SUPABASE_KEY=your_test_supabase_key

# Use test AWS region (consistent)
TEST_AWS_REGION=us-east-1

# Test ChromaDB path
TEST_CHROMADB_PATH=./test_chromadb

# Test API keys (use sandbox/test keys if available)
TEST_GEMINI_API_KEY=your_test_gemini_key
TEST_APIFY_API_KEY=your_test_apify_key
