# InstaMedia AI v3 — Environment Variables
# Copy this to .env.local and fill in your values

# LLM Provider (gemini | groq | openai)
LLM_PROVIDER=gemini

# API Keys
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# Supabase (server-side — service role for full access)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (client-side — anon key only, exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AWS (for Bedrock Titan image generation)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Apify (web scraping)
APIFY_API_KEY=
